# ── Konfiguracja SMTP ────────────────────────────────────────────
# Gmail: host=smtp.gmail.com, port=587, secure=false
# Outlook/Hotmail: host=smtp-mail.outlook.com, port=587, secure=false
# Własny serwer: wpisz dane od hostingu

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Konto z którego wysyłamy (login do skrzynki)
SMTP_USER=twoj@email.com

# Hasło – dla Gmaila użyj "hasła do aplikacji" (nie zwykłego hasła)
# Wygeneruj: Google → Konto → Bezpieczeństwo → Hasła do aplikacji
SMTP_PASS=twoje_haslo_do_aplikacji

# ── Adresat maili z formularzem ──────────────────────────────────
MAIL_TO=rekrutacja@cukru.cafe

# ── Serwer ───────────────────────────────────────────────────────
PORT=3000

# ── Panel admina ──────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=zmien_to_haslo
SESSION_SECRET=losowy_dlugi_ciag_znakow
